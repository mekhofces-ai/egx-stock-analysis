# EGX Telegram Signal Analyst MVP (Python)
APP_ENV=development
LOG_LEVEL=INFO
EGX_DATABASE_URL=sqlite:///./egx_signals.db
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# Telegram reader credentials from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=egx_telegram
TELEGRAM_SOURCE_CHANNELS=@sample_channel
TELEGRAM_FETCH_LIMIT_PER_CHANNEL=100

# Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_PRIVATE_CHAT_ID=
# Optional aliases also supported:
TELEGRAM_PRIVATE_CHAT_ID=
PRIVATE_CHAT_ID=
TELEGRAM_BOT_EMBEDDED_ENABLED=false
TELEGRAM_BOT_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_VERIFY_TLS=true
TELEGRAM_ALERT_ENABLED=true
TELEGRAM_ALERT_DECISIONS=BUY
TELEGRAM_ALERT_MIN_CONFIDENCE=70
TELEGRAM_ALERT_RECOMMENDATIONS_ENABLED=true
TELEGRAM_ALERT_REQUIRE_TELEGRAM_CONFIRMATION=true
TELEGRAM_ALERT_SCAN_INTERVAL_MINUTES=5

# Provider priority: TradingView screener is a snapshot source; TradingView chart session / CSV provide OHLCV.
MARKET_DATA_PROVIDER_PRIORITY=tradingview_screener,tradingview_websocket,csv
MARKET_DATA_ALLOW_MOCK=false
ALLOW_INSECURE_MARKET_DATA_TLS=false
TRADINGVIEW_AUTH_TOKEN=unauthorized_user_token
TRADINGVIEW_WS_URL=wss://data.tradingview.com/socket.io/websocket
CSV_DATA_DIR=data/ohlcv
CSV_OHLCV_SAMPLE_PATH=data/ohlcv_sample.csv
MARKET_DEPTH_DATA_DIR=data/market_depth
IMAGE_DOWNLOAD_DIR=data/images

SCHEDULER_ENABLED=true
TELEGRAM_FETCH_INTERVAL_MINUTES=5
ANALYSIS_INTERVAL_MINUTES=5
PERFORMANCE_INTERVAL_MINUTES=5
DAILY_REPORT_HOUR=17
STRATEGY_BACKTEST_BARS=260
STRATEGY_SYMBOL_LIMIT=30
STRATEGY_TIMEFRAMES=15m,1h,4h,1D
STRATEGY_ALLOW_MOCK_DATA=false
STRATEGY_MAX_DAILY_AGE_DAYS=14
STRATEGY_MAX_INTRADAY_AGE_DAYS=7
STRATEGY_PRICE_TOLERANCE_PERCENT=15
DAILY_REPORT_INCLUDE_STRATEGY=true
DAILY_REPORT_TOP_N=10
NIGHT_OPPORTUNITY_REPORT_ENABLED=true
NIGHT_OPPORTUNITY_REPORT_HOUR=21
NIGHT_OPPORTUNITY_TOP_N=7
TIMEZONE=Africa/Cairo
DEFAULT_RISK_PER_TRADE_PERCENT=1.0
OPPORTUNITY_WEIGHT_RECOMMENDATION=30
OPPORTUNITY_WEIGHT_STRATEGY=20
OPPORTUNITY_WEIGHT_BACKTEST=20
OPPORTUNITY_WEIGHT_TRADINGVIEW=20
OPPORTUNITY_WEIGHT_TELEGRAM=10

# Existing Node/React dashboard settings retained for compatibility.
DATABASE_URL="file:./dev.db"
PORT=8788
NODE_ENV=development
MARKET_DATA_PROVIDER=egx-ai-api
LICENSED_API_BASE_URL=""
LICENSED_API_KEY=""
LICENSED_API_TIMEOUT_MS=8000
EGX_AI_API_BASE_URL="http://localhost:8100"
EGX_AI_API_TIMEOUT_MS=8000
TWELVE_DATA_API_KEY=""
TWELVE_DATA_EXCHANGE="EGX"
TWELVE_DATA_SYMBOL_MAP_JSON="{}"
REFINITIV_WS_URL=""
REFINITIV_AUTH_MODE="ads"
REFINITIV_WS_USERNAME=""
REFINITIV_WS_PASSWORD=""
REFINITIV_WS_CLIENT_ID=""
REFINITIV_WS_CLIENT_SECRET=""
REFINITIV_WS_APP_ID="256"
REFINITIV_WS_POSITION="127.0.0.1/net"
REFINITIV_WS_SERVICE=""
REFINITIV_RIC_SUFFIX=".CA"
REFINITIV_WS_VIEW_FIELDS=""
REFINITIV_WS_TIMEOUT_MS=10000
REFINITIV_WS_MAX_BATCH_SIZE=80
REFINITIV_AUTH_URL_V1="https://api.refinitiv.com:443/auth/oauth2/v1/token"
REFINITIV_AUTH_URL_V2="https://api.refinitiv.com/auth/oauth2/v2/token"
REFINITIV_DISCOVERY_URL="https://api.refinitiv.com/streaming/pricing/v1/"
REFINITIV_REGION="us-east-1"
REFINITIV_SCOPE="trapi.streaming.pricing.read"
CACHE_TTL_MS=300000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_ON_START=true
AUTO_REFRESH_INTERVAL_MS=300000
ENABLE_MOCK_PROVIDER=false
ALLOW_INSECURE_MARKET_DATA_TLS=false
AUTHORIZED_MARKET_WS_URL=""
AUTHORIZED_MARKET_WS_API_KEY=""
AUTHORIZED_MARKET_WS_SOURCE="authorized-websocket"
AUTHORIZED_MARKET_WS_BACKEND_IMPORT_URL="http://localhost:8788/api/import/candles"
AUTHORIZED_MARKET_WS_RECONNECT_MS=5000
AUTHORIZED_MARKET_WS_HEADERS_JSON="{}"
AUTHORIZED_MARKET_WS_SUBSCRIPTIONS="[]"
